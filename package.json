{
	"name": "@tadashi/mask",
	"version": "4.4.0",
	"description": "The simple and tiny script for input mask",
	"keywords": [
		"mask",
		"input",
		"tiny"
	],
	"bug": {
		"url": "https://github.com/lagden/mask",
		"email": "lagden@gmail.com"
	},
	"license": "MIT",
	"author": {
		"name": "Thiago Lagden",
		"email": "lagden@gmail.com"
	},
	"type": "module",
	"main": "dist/mask.cjs",
	"types": "types/mask.d.ts",
	"exports": {
		".": {
			"types": "./types/mask.d.ts",
			"browser": "./src/mask.js",
			"import": "./src/mask.js",
			"require": "./dist/mask.cjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"src",
		"dist",
		"types",
		"license",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lagden/mask.git"
	},
	"scripts": {
		"tsc": "tsc",
		"rollup": "rollup -c",
		"lint": "deno lint",
		"check": "deno fmt --check",
		"format": "deno fmt",
		"pretest": "run-s check lint tsc",
		"posttest": "run-s rollup",
		"test": "mkdir -p coverage && node --test --experimental-test-coverage --test-coverage-include='src/**' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info test/*.spec.js"
	},
	"devDependencies": {
		"jsdom": "29.1.1",
		"@types/node": "25.9.2",
		"npm-run-all": "4.1.5",
		"typescript": "6.0.3",
		"@rollup/plugin-commonjs": "29.0.3",
		"rollup": "4.61.1"
	}
}
