{
	"compilerOptions": {
		"moduleResolution": "nodenext",
		"module": "nodenext",
		"target": "esnext",
		"declaration": true,
		"emitDeclarationOnly": true,
		"allowJs": true,
		"checkJs": true,
		"rootDir": "./src",
		"outDir": "./types"
	},
	"include": ["./src/**/*.js"],
	"exclude": ["./types/**/*.d.ts"]
}
